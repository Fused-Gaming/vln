{
  "framework": "nextjs",
  "regions": ["iad1"],
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "devCommand": "pnpm dev",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "integration/vln": true
    }
  },
  "headers": [
    {
      "source": "/api/blog/rss",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/rss+xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
