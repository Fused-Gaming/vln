---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
  <nav>
    <div class="site-title">
      <a href="/">{SITE_TITLE}</a>
    </div>
    <div class="internal-links">
      <HeaderLink href="/">Posts</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
    <div class="social-links">
      <a href="https://vln.gg" target="_blank" rel="noopener noreferrer">vln.gg</a>
      <a href="/rss.xml" title="RSS Feed">RSS</a>
    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0 1em;
    background: var(--vln-bg);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1024px;
    margin: 0 auto;
    padding: 0.75rem 0;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .site-title a {
    font-weight: 700;
    font-size: 1.1rem;
    color: #f5f5f5;
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .site-title a span {
    color: var(--vln-sage);
  }
  .internal-links,
  .social-links {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }
  .social-links a {
    color: var(--vln-bluegray);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.15s ease;
  }
  .social-links a:hover {
    color: var(--vln-sage);
  }
</style>
